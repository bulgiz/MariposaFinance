# RPC URLs (defaults to public RPCs if not set)
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Optional: Premium RPC providers
ALCHEMY_API_KEY=
QUICKNODE_API_KEY=

# API
API_PORT=3001
API_HOST=0.0.0.0

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_VAULT_WRITES=false
NEXT_PUBLIC_ENABLE_SWAP=true

# 1inch API (swap)
ONEINCH_API_KEY=
MARIPOSA_FEE_WALLET=
MARIPOSA_FEE_PERCENT=0.15
